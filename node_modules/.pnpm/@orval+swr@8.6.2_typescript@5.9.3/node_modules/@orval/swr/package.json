{
  "name": "@orval/swr",
  "version": "8.6.2",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map",
    "!dist/**/*.d.mts.map"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "tsdown --config-loader unrun --watch src",
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .turbo dist",
    "nuke": "rimraf .turbo dist node_modules"
  },
  "dependencies": {
    "@orval/core": "8.6.2",
    "@orval/fetch": "8.6.2"
  },
  "devDependencies": {
    "eslint": "9.39.2",
    "rimraf": "6.1.2",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  }
}
